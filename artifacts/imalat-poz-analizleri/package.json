{
  "name": "@workspace/imalat-poz-analizleri",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/fix-expo-router-stub.js",
    "dev": "node scripts/dev-gateway.mjs",
    "dev:metro": "node scripts/fix-expo-router-stub.js && EXPO_NO_DEPENDENCY_VALIDATION=1 pnpm exec expo start --lan --port ${PORT:-24916}",
    "dev:tunnel": "node scripts/fix-expo-router-stub.js && EXPO_NO_DEPENDENCY_VALIDATION=1 pnpm exec expo start --tunnel --port ${PORT:-24916}",
    "dev:web": "EXPO_NO_DEPENDENCY_VALIDATION=1 pnpm exec expo start --web --localhost --port ${PORT:-24916}",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "54.0.23",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.11",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "expo-file-system": "~19.0.22",
    "expo-sharing": "~14.0.8"
  }
}
